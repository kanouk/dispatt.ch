# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Domain Configuration
VITE_ROOT_DOMAIN=dispatt.ch
VITE_APP_ORIGIN=https://app.dispatt.ch

# Admin Configuration (comma-separated email list)
VITE_ADMIN_EMAILS=admin@dispatt.ch,manager@dispatt.ch

# Optional Configuration
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL_POOLING=postgresql://user:password@host:6543/database?pgbouncer=true
FORCE_PERMANENT_REDIRECT=false
IP_HASH_SALT=your-random-salt-string